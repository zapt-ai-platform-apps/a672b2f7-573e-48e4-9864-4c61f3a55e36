{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/*.ts": {
      "includeFiles": "../drizzle/schema.ts,../src/utils/playerParsingUtils.js,../src/models/squadModel.js"
    }
  }
}